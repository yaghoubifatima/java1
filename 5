/* 5)Düzbucaqlının kənarlarının uzunluğunu bilirsinizsə, onun perimetrini və sahəsini tapın.
Giriş 3 7 -> Cavab : 20 21 */


import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        int a = sc.nextInt();
        int b = sc.nextInt();

        System.out.println(2 * (a + b) + " " + (a * b));

    }
}
